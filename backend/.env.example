# Server
PORT=4000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Local development: install Postgres and create a database, e.g.
#   createdb duncan_funded
# Then set the connection string below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/duncan_funded

# On Railway: DATABASE_URL is injected automatically when you attach a
# Postgres database to the service — you do not set it manually there.

# SSL: enabled automatically when NODE_ENV=production (required by Railway).
# For a local Postgres without SSL, leave NODE_ENV=development, or set:
# PGSSL=disable

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Public site URL (used for unsubscribe links etc.)
SITE_URL=http://localhost:3000

# Admin API key — protects admin write endpoints.
# Generate a long random value, e.g.:  openssl rand -hex 32
ADMIN_API_KEY=change-me-to-a-long-random-string
