# Server
PORT=4000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Local development: create a database (e.g. createdb duncan_funded) and set:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/duncan_funded
# On Railway, DATABASE_URL is injected automatically when a Postgres database
# is attached to the service.
# SSL is enabled automatically when NODE_ENV=production.
# For a local Postgres without SSL: PGSSL=disable

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Public site URL (used for unsubscribe links etc.)
SITE_URL=http://localhost:3000

# --- Admin authentication (Phase 2) ---
# JWT signing secret — generate a long random value:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# First admin account — used by `npm run setup:admin`.
ADMIN_EMAIL=admin@duncanfunded.com
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_NAME=Site Admin
