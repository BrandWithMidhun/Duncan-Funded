# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Public site URL (used for unsubscribe links etc.)
SITE_URL=http://localhost:3000

# Admin API key — protects write endpoints (admin routes).
# Phase 2 (CMS) replaces this with proper user auth + JWT.
ADMIN_API_KEY=change-me-to-a-long-random-string

# --- Database ---
# Phase 1 uses an embedded SQLite database (sql.js / WASM) stored at
# backend/data/duncan.db — no configuration needed.
# For the CMS phase, the data layer (src/lib/db.js) can be swapped for a
# Postgres driver; set the connection string here when you do.
# DATABASE_URL="postgresql://user:pass@localhost:5432/duncan_funded"
